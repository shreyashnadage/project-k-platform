[Unit]
Description=OCEN Platform - Temporal Worker
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/platform
Environment=PATH=/root/.local/bin:/usr/local/bin:/usr/bin
ExecStart=/root/.local/bin/uv run python -m services.la_orchestrator.worker
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
