#!/bin/bash
# RKE2 worker bootstrap — templated by Terraform (rke2.tf).
# Logs to /var/log/rke2-bootstrap.log for post-mortem via SSM.
set -euxo pipefail
exec > >(tee -a /var/log/rke2-bootstrap.log) 2>&1

echo "=== Installing AWS CLI v2 ==="
apt-get update -y
apt-get install -y unzip curl
curl -sS "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip
unzip -q /tmp/awscliv2.zip -d /tmp
/tmp/aws/install
rm -rf /tmp/awscliv2.zip /tmp/aws

echo "=== Waiting for control-plane to publish the join token (up to 10 min) ==="
TOKEN=""
for i in $(seq 1 60); do
  TOKEN=$(aws ssm get-parameter \
    --region "${aws_region}" \
    --name "${token_parameter_name}" \
    --with-decryption \
    --query 'Parameter.Value' \
    --output text 2>/dev/null || true)
  if [ -n "$TOKEN" ] && [ "$TOKEN" != "None" ]; then
    break
  fi
  sleep 10
done

if [ -z "$TOKEN" ] || [ "$TOKEN" = "None" ]; then
  echo "FATAL: join token never appeared in SSM after 10 minutes" >&2
  exit 1
fi

echo "=== Writing RKE2 agent config ==="
mkdir -p /etc/rancher/rke2
cat > /etc/rancher/rke2/config.yaml <<EOF
server: https://${server_private_ip}:9345
token: $TOKEN
EOF
chmod 600 /etc/rancher/rke2/config.yaml

echo "=== Installing RKE2 agent (channel: ${rke2_version}) ==="
curl -sfL https://get.rke2.io | INSTALL_RKE2_CHANNEL="${rke2_version}" INSTALL_RKE2_TYPE="agent" sh -

systemctl enable rke2-agent.service
systemctl start rke2-agent.service

echo "=== RKE2 agent bootstrap complete ==="
