{
  "$id": "https://ocen-platform/schemas/borrower.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Borrower / Vendor Identity",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "phone": {
          "type": "string",
          "title": "Phone number",
          "ory.sh/kratos": {
            "credentials": {
              "password": { "identifier": true }
            },
            "verification": { "via": "sms" },
            "recovery": { "via": "sms" }
          }
        },
        "org_type": {
          "type": "string",
          "title": "Organization type",
          "enum": ["vendor", "anchor"],
          "default": "vendor"
        },
        "gstin": {
          "type": "string",
          "title": "GSTIN",
          "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$"
        },
        "udyam_number": {
          "type": "string",
          "title": "Udyam registration number"
        },
        "enterprise_name": {
          "type": "string",
          "title": "Enterprise / business name"
        }
      },
      "required": ["phone"],
      "additionalProperties": false
    }
  }
}
