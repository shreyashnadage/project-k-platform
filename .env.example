# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://ocen:ocen_dev@localhost:5432/ocen_platform
AGE_DATABASE_URL=postgresql://ocen:ocen_dev@localhost:5433/ocen_graph

# ─── Redpanda / Kafka ──────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
SCHEMA_REGISTRY_URL=http://localhost:18081

# ─── Temporal ───────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=loan-origination

# ─── Keycloak ───────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ocen-platform
KEYCLOAK_CLIENT_ID=la-orchestrator
KEYCLOAK_CLIENT_SECRET=dev-secret-la-orchestrator

# ─── Audit / Signing ───────────────────────────────────────
RECEIPT_SIGNING_KEY=dev-signing-key-do-not-use-in-prod
# In production: AWS_KMS_KEY_ID=arn:aws:kms:ap-south-1:...

# ─── Account Aggregator (Setu) ─────────────────────────────
# AA_BASE_URL=https://fiu-sandbox.setu.co
# AA_CLIENT_ID=
# AA_CLIENT_SECRET=

# ─── Integration Mode ──────────────────────────────────────
# REQUIRED: "sandbox" (uses simulated clients) or "live" (real APIs)
# No default — app fails to start if unset.
INTEGRATION_MODE=sandbox

# ─── Sandbox Tuning (only used when INTEGRATION_MODE=sandbox) ─
# SANDBOX_RESPONSE_DELAY_MS=0
# SANDBOX_AA_AUTO_APPROVE=true
# SANDBOX_LENDER_AUTO_APPROVE=true
# SANDBOX_LENDER_MAX_AMOUNT=1000000.00
# SANDBOX_LENDER_INTEREST_RATE=14.5
# SANDBOX_LENDER_TENURE_DAYS=90

# ─── Frappe Back-Office Integration ────────────────────────
FRAPPE_URL=http://172.31.21.194
FRAPPE_API_KEY=your-frappe-api-key
FRAPPE_API_SECRET=your-frappe-api-secret
FRAPPE_WEBHOOK_SECRET=ocen-wh-secret-2026-prod

# ─── Ops API (for Frappe → Platform commands) ─────────────
OPS_API_KEY=ops-api-key-2026-prod

# ─── DPDP Compliance ──────────────────────────────────────
DPDP_RBAC_ENABLED=false
DPDP_CONFIG_PATH=dpdp_config.yaml
# DPDP_ENCRYPTION_KEY=  # Generate: python -c "import secrets; print(secrets.token_hex(32))"
# DPDP_BLIND_INDEX_KEY=  # Generate: python -c "import secrets; print(secrets.token_hex(32))"
# DPDP_SANDBOX_CONSENT_DENIED=false
# DPDP_DPBI_NOTIFICATION_URL=

# ─── OCEN Network Protocol ─────────────────────────────────
# OCEN_CLIENT_ID=your-client-id
# OCEN_CLIENT_SECRET=your-client-secret
# OCEN_TOKEN_URL=https://auth.ocen.network/realms/dev/protocol/openid-connect/token
# OCEN_REGISTRY_BASE_URL=https://dev.ocen.network/service
# OCEN_HEARTBEAT_URL=https://analytics-dev.ocen.network/ocen/v4/event
# OCEN_PARTICIPANT_ID=your-participant-id
# OCEN_ORG_ID=your-org-id
# OCEN_PRODUCT_ID=your-product-id
# OCEN_PRODUCT_NETWORK_ID=your-product-network-id
# OCEN_KEYPAIR_PATH=secrets/ocen_keypair.json
